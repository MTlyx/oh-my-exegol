alias adaptix-server='adaptixserver'
alias adaptix-client='adaptixclient &> /dev/null &'

alias tun0='ip=$(ip -4 addr show dev tun0 2>/dev/null | grep -oP "(?:[0-9]{1,3}\.){3}[0-9]{1,3}" | head -1); if [ -z "$ip" ]; then echo "tun0: interface not found or no IP assigned"; else printf "%s" "$ip" | xclip -selection clipboard 2>/dev/null && echo "tun0 ip copied: $ip"; fi'
